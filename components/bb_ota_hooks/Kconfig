menu "breadboard: bb_ota_hooks"

config BB_OTA_HOOKS_AUTO_ATTACH
    bool "Auto-attach ota.progress to /api/events"
    default y
    depends on BB_EVENT_ROUTES_AUTOREGISTER
    help
        Surface OTA progress as the retained 'ota.progress' SSE topic on /api/events
        ({"via":...,"state":...,"pct":N}) for push, pull, and boot uniformly. Retained
        (B1-546) so a client connecting mid-update replays the latest progress entry
        instead of empty state; the ring holds only the single most recent update.

endmenu
