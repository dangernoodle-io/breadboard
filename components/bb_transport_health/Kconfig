menu "breadboard: bb_transport_health"

config BB_TRANSPORT_HEALTH_MAX_SLOTS
    int "Maximum registered transport slots"
    default 8
    range 1 16
    help
        Fixed-capacity slot table for per-transport connectivity health.
        bb_transport_health_register() returns BB_ERR_NO_SPACE once this
        many transports are registered.

config BB_TRANSPORT_HEALTH_INFERRED_STALE_S
    int "Inferred-transport staleness threshold (seconds)"
    default 60
    range 5 3600
    help
        An INFERRED transport slot is considered failing (at snapshot time)
        when no activity has been marked for this many seconds.

endmenu
