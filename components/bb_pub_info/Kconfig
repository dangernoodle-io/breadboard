menu "breadboard: bb_pub_info"

config BB_PUB_INFO_AUTO_ATTACH
    bool "Auto-register info telemetry source with bb_pub"
    default y
    depends on BB_PUB_AUTOREGISTER
    help
        When enabled, bb_pub_info self-registers at the PRE_HTTP tier (after
        bb_pub) so device info / heap metrics are published on every bb_pub
        tick under the "info" subtopic. Disable to call
        bb_pub_info_register() manually.

endmenu
