menu "breadboard: bb_cache_routes"

config BB_CACHE_ROUTES_BUF_BYTES
    int "Stack buffer size for the serialized cache snapshot (bytes)"
    default 768
    range 128 2048
    help
        Buffer used by the GET /api/cache handler to hold the
        bb_cache_get_serialized() envelope for one key. Must be large enough
        to hold the largest registered key's {"ts_ms":N,"data":{...}}
        envelope, or the handler returns 500 (BB_ERR_NO_SPACE).

        This buffer is stack-allocated on the httpd worker task and must
        stay well under CONFIG_BB_HTTP_TASK_STACK_SIZE (default 6144).

endmenu
