menu "breadboard: bb_pub_thermal"

config BB_PUB_THERMAL_AUTO_ATTACH
    bool "Auto-register thermal telemetry source with bb_pub"
    default y
    depends on BB_PUB_AUTOREGISTER
    help
        When enabled, bb_pub_thermal self-registers at the PRE_HTTP tier (after
        bb_pub) so aggregate temperature readings are published on every bb_pub
        tick under the "thermal" subtopic. Disable to call
        bb_pub_thermal_register() manually.

endmenu
