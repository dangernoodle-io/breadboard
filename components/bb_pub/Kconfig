menu "breadboard: bb_pub"

config BB_PUB_MAX_SOURCES
    int "Maximum number of registered telemetry sources"
    default 8
    range 1 64
    help
        Capacity of the source registry. Attempting to register more sources
        than this returns BB_ERR_NO_SPACE. A high-watermark warning is logged
        when the registry reaches capacity minus one.

config BB_PUB_MAX_SINKS
    int "Maximum number of concurrent telemetry sinks"
    default 4
    range 1 8
    help
        Capacity of the sink array for fan-out publishing. Attempting to add
        more sinks than this returns BB_ERR_NO_SPACE. bb_pub_set_sink (single-
        sink back-compat) replaces all sinks with one, so this limit only
        applies to callers using bb_pub_add_sink directly.

config BB_PUB_TOPIC_PREFIX
    string "MQTT topic prefix for published telemetry"
    default "metrics"
    help
        The first segment of the publish topic:
          <BB_PUB_TOPIC_PREFIX>/<hostname>/<subtopic>

config BB_PUB_INTERVAL_MS
    int "Telemetry publish interval in milliseconds"
    default 10000
    range 1000 3600000
    help
        How often bb_pub fires the sample+publish cycle on ESP-IDF (via
        bb_timer periodic). Not used on host (call bb_pub_tick_once() directly).

config BB_PUB_AUTOREGISTER
    bool "Auto-register bb_pub init via bb_registry (PRE_HTTP tier)"
    default y
    help
        When enabled, bb_pub self-registers at the PRE_HTTP tier, which starts
        the periodic worker task. Disable to call bb_pub_start manually.

config BB_PUB_WORKER_STACK
    int "bb_pub telemetry worker task stack (bytes)"
    default 8192 if (BB_MQTT_TLS_ENABLE || BB_HTTP_TLS_ENABLE)
    default 4096
    range 2048 16384
    help
        FreeRTOS task stack for the bb_pub periodic worker. The worker calls
        each sink's publish() synchronously, so the stack must cover the
        heaviest sink in use:

          - HTTP/TLS or MQTT/TLS sink: needs >= 8192 bytes to cover the mbedTLS
            handshake + cert-bundle parse. The default auto-sizes to 8192 when
            BB_MQTT_TLS_ENABLE or BB_HTTP_TLS_ENABLE is on.
          - Plaintext MQTT or plaintext HTTP: 4096 is sufficient and saves ~4 KB
            RAM. The default auto-sizes to 4096 when both TLS gates are OFF.

        Gate-keyed defaults (B1-274): default 8192 with any TLS gate; 4096
        without. Override in sdkconfig if your specific sink mix differs.

config BB_PUB_BUFFER_ENABLE
    bool "Enable store-and-forward ring buffer (capture on sink error, replay on recovery)"
    default n
    help
        When enabled, bb_pub captures serialized topic+payload entries into a
        bb_ring when the first sink returns non-BB_OK. On the next tick where
        the sink succeeds, buffered entries are replayed oldest-first. Requires
        bb_ring. The entire feature compiles out when this is disabled.

config BB_PUB_BUFFER_MAX_ENTRIES
    int "Store-and-forward ring capacity (entries)"
    default 16
    range 1 256
    depends on BB_PUB_BUFFER_ENABLE
    help
        Maximum number of buffered topic+payload entries. When the ring is
        full, the oldest entry is evicted and the dropped counter increments.

config BB_PUB_BUFFER_MAX_PAYLOAD_BYTES
    int "Store-and-forward maximum entry size (bytes)"
    default 256
    range 64 4096
    depends on BB_PUB_BUFFER_ENABLE
    help
        Maximum size (bytes) for a single ring entry. Each entry packs:
          topic (up to 192 bytes) + 1-byte NUL separator + payload.
        Entries larger than this limit are rejected (truncated counter++).
        The actual ring max_entry_bytes = BB_PUB_BUFFER_MAX_PAYLOAD_BYTES +
        192 (topic budget) + 1 (separator).

endmenu
