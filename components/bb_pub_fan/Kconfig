menu "breadboard: bb_pub_fan"

config BB_PUB_FAN_AUTO_ATTACH
    bool "Auto-register fan telemetry source with bb_pub"
    default y
    depends on BB_PUB_AUTOREGISTER
    help
        When enabled, bb_pub_fan self-registers at the PRE_HTTP tier (after
        bb_pub) so fan readings are published on every bb_pub tick under
        the "fan" subtopic. Disable to call bb_pub_fan_register() manually.

endmenu
