menu "breadboard: bb_alert"

config BB_ALERT_ENABLE
    bool "Enable bb_alert one-shot alert event channel"
    default n
    help
        When disabled, bb_alert_emit() compiles to a safe no-op and the
        alert topic is not registered or attached. Callers can invoke
        bb_alert_emit() unconditionally at zero cost.

        When enabled, discrete alert events are surfaced on /api/events
        under the "alert" topic (non-retained). Each event carries a JSON
        envelope: {type, severity, uptime_ms, ...fill fields}.

config BB_ALERT_MIN_SEVERITY
    int "Minimum alert severity to emit (0=INFO, 1=WARNING, 2=CRITICAL)"
    default 0
    range 0 2
    depends on BB_ALERT_ENABLE
    help
        Alerts with severity below this threshold are silently dropped.
        0 = emit all (INFO and above). 1 = WARNING and above. 2 = CRITICAL only.

        The C default and this Kconfig default both equal 0 so the bridge
        is never silently inert.

endmenu
