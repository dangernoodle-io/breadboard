menu "breadboard: bb_telemetry"

config BB_TELEMETRY_AUTOREGISTER
    bool "Auto-register /api/telemetry HTTP routes via bb_registry"
    default y
    help
        When enabled, bb_telemetry self-registers GET and PATCH /api/telemetry
        through bb_registry at order 5. Disable to call bb_telemetry_init
        manually.

config BB_TELEMETRY_MAX_SECTIONS
    int "Maximum number of registered telemetry sections"
    default 4
    range 1 16
    help
        Fixed-array capacity for section providers registered via
        bb_telemetry_register_section. Default 4 covers mqtt, http,
        and publisher with one spare.

endmenu
