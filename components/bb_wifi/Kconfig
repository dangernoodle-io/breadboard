menu "breadboard: bb_wifi (routes)"

config BB_WIFI_RSSI_GOOD
    int "RSSI threshold for GOOD link bucket (dBm)"
    default -67
    range -100 0
    help
        RSSI >= this value is classified as GOOD. Moved from bb_net_health
        (net_health teardown PR-B); a saved sdkconfig override of the old
        BB_NET_HEALTH_RSSI_GOOD name silently reverts to this default.

config BB_WIFI_RSSI_MARGINAL_LO
    int "Lower RSSI threshold for MARGINAL link bucket (dBm)"
    default -75
    range -100 0
    help
        RSSI in the range [BB_WIFI_RSSI_MARGINAL_LO ..
        BB_WIFI_RSSI_GOOD-1] is classified as MARGINAL. RSSI below this
        value is classified as POOR. Moved from bb_net_health (net_health
        teardown PR-B); a saved sdkconfig override of the old
        BB_NET_HEALTH_RSSI_MARGINAL_LO name silently reverts to this
        default.

config BB_WIFI_HYST_DOWN
    int "Hysteresis sample count before downgrading link state"
    default 3
    range 1 10
    help
        Number of consecutive worse-bucket RSSI samples required before the
        published link state is downgraded. Prevents single-sample flaps.
        Moved from bb_net_health (net_health teardown PR-B); a saved
        sdkconfig override of the old BB_NET_HEALTH_HYST_DOWN name silently
        reverts to this default.

config BB_WIFI_HYST_UP
    int "Hysteresis sample count before upgrading link state"
    default 3
    range 1 10
    help
        Number of consecutive better-bucket RSSI samples required before the
        published link state is upgraded. Moved from bb_net_health
        (net_health teardown PR-B); a saved sdkconfig override of the old
        BB_NET_HEALTH_HYST_UP name silently reverts to this default.

config BB_WIFI_RECONFIGURE
    bool "Enable runtime wifi reconfigure + pending-creds try on boot"
    default y
    help
        Enables bb_wifi_reconfigure() which stages new credentials and reboots
        to try them. On boot, if pending creds get an IP they are committed as
        the new live credentials. On timeout the pending creds are cleared and
        the device reboots onto the prior live creds without incrementing
        boot_count. When disabled bb_wifi_reconfigure() returns BB_ERR_UNSUPPORTED
        and the autoinit path is byte-for-byte identical to the baseline.

config BB_WIFI_PENDING_TRY_TIMEOUT_S
    int "Bounded connect timeout for a runtime wifi reconfigure try (seconds)"
    default 30
    range 10 120
    depends on BB_WIFI_RECONFIGURE
    help
        Maximum time (seconds) to wait for an IP when attempting to connect
        with pending (staged) credentials. On timeout the pending creds are
        discarded, the device reboots onto the prior live credentials, and
        boot_count is NOT incremented.

config BB_WIFI_RECONN_CONNECTING_TIMEOUT_MS
    int "WiFi ST_CONNECTING watchdog timeout (ms)"
    range 5000 120000
    default 30000
    help
        If neither GOT_IP nor DISCONNECT arrives within this window after
        issuing esp_wifi_connect(), the reconnect manager treats the
        association as stalled, re-issues esp_wifi_disconnect +
        esp_wifi_connect, and stays in ST_CONNECTING. 30 s >> normal
        associate+DHCP (2–8 s), so false positives are rare.

config BB_WIFI_RECONN_PERSISTENT_FAIL_WINDOW_S
    int "WiFi persistent-fail safeguard reboot window (seconds)"
    range 60 3600
    default 300
    help
        If the device keeps failing to connect for longer than this window
        (measured from the first disconnect after boot), the reconnect
        manager triggers a safeguard reboot. Default 300 s (5 minutes)
        matches the legacy hard-coded value. On validated firmware the
        reboot does not increment boot_count.

config BB_WIFI_RECONN_HANDSHAKE_FAST_RETRY_LIMIT
    int "WiFi handshake-failure fast-retry limit (attempts)"
    range 0 50
    default 3
    help
        Number of consecutive handshake-timeout disconnects that retry
        immediately (no backoff) before the reconnect manager escalates to
        the tier-2 backoff delay.

config BB_WIFI_RECONN_HANDSHAKE_TIER2_LIMIT
    int "WiFi handshake-failure tier-2 backoff limit (attempts)"
    range 0 100
    default 6
    help
        Number of consecutive handshake-timeout disconnects, beyond the
        fast-retry limit, that back off at the tier-2 delay before the
        reconnect manager escalates to the tier-3 delay.

config BB_WIFI_RECONN_HANDSHAKE_BACKOFF_TIER2_MS
    int "WiFi handshake-failure tier-2 backoff delay (ms)"
    range 1000 120000
    default 10000
    help
        Backoff delay applied after a handshake-timeout disconnect once the
        fast-retry limit is exceeded but the tier-2 limit is not.

config BB_WIFI_RECONN_HANDSHAKE_BACKOFF_TIER3_MS
    int "WiFi handshake-failure tier-3 backoff delay (ms)"
    range 1000 300000
    default 30000
    help
        Backoff delay applied after a handshake-timeout disconnect once
        both the fast-retry and tier-2 limits are exceeded.

config BB_WIFI_RECONN_GENERIC_FAST_RETRY_LIMIT
    int "WiFi generic-failure fast-retry limit (attempts)"
    range 0 50
    default 10
    help
        Number of consecutive non-handshake disconnects that retry
        immediately (no backoff) before the reconnect manager applies the
        generic backoff pause.

config BB_WIFI_RECONN_GENERIC_BACKOFF_PAUSE_MS
    int "WiFi generic-failure backoff pause (ms)"
    range 1000 120000
    default 5000
    help
        Backoff delay applied after a non-handshake disconnect once the
        generic fast-retry limit is exceeded.

config BB_WIFI_RECONN_SLOW_TIER1_LIMIT
    int "WiFi slow-failure tier-1 limit (attempts)"
    range 0 50
    default 3
    help
        Number of consecutive AUTH_FAIL/NO_AP_FOUND disconnects (bad
        credentials or an absent AP) that back off at the tier-1 delay
        before the reconnect manager escalates to the tier-2 delay. Unlike
        the generic ladder, the SLOW tier never hot-retries -- even the
        first occurrence backs off.

config BB_WIFI_RECONN_SLOW_BACKOFF_TIER1_MS
    int "WiFi slow-failure tier-1 backoff delay (ms)"
    range 1000 120000
    default 30000
    help
        Backoff delay applied after an AUTH_FAIL/NO_AP_FOUND disconnect up
        to the tier-1 limit.

config BB_WIFI_RECONN_SLOW_BACKOFF_TIER2_MS
    int "WiFi slow-failure tier-2 backoff delay (ms)"
    range 1000 300000
    default 120000
    help
        Backoff delay applied after an AUTH_FAIL/NO_AP_FOUND disconnect
        once the tier-1 limit is exceeded.

choice BB_WIFI_POWER_SAVE
    prompt "WiFi power-save mode"
    default BB_WIFI_PS_MIN_MODEM
    help
        WiFi modem power-save. MIN_MODEM (default) sleeps the radio between
        beacons to save power but can cause beacon-miss/idle disconnects on
        quiet links; NONE keeps the radio always on for best link stability
        (recommended for mains-powered/always-on devices like miners).
    config BB_WIFI_PS_NONE
        bool "None (radio always on)"
    config BB_WIFI_PS_MIN_MODEM
        bool "Minimum modem sleep"
    config BB_WIFI_PS_MAX_MODEM
        bool "Maximum modem sleep"
endchoice

config BB_WIFI_INACTIVE_TIME_ENABLE
    bool "Enable beacon-loss detection via esp_wifi_set_inactive_time"
    default n
    help
        When enabled, calls esp_wifi_set_inactive_time(WIFI_IF_STA,
        CONFIG_BB_WIFI_INACTIVE_TIME_S) after esp_wifi_start() and after
        each bb_wifi_restart_sta() so the driver emits
        WIFI_EVENT_STA_DISCONNECTED after beacon starvation. The resulting
        disconnect flows into the normal reconnect FSM.

config BB_WIFI_INACTIVE_TIME_S
    int "Inactive time for beacon-loss detection (seconds)"
    range 3 600
    default 45
    depends on BB_WIFI_INACTIVE_TIME_ENABLE
    help
        Configures the WiFi driver's inactive time via
        esp_wifi_set_inactive_time(). If the station receives no beacon
        from the AP within this window, the driver emits
        WIFI_EVENT_STA_DISCONNECTED. Minimum 3 (ESP-IDF hard floor).

config BB_WIFI_RECOVERY_COOLDOWN_S
    int "App-driven recovery request cooldown (seconds)"
    range 10 3600
    default 60
    help
        Minimum interval between consecutive bb_wifi_request_recovery()
        actions. Requests within the cooldown window are logged and
        discarded. The hook API is always compiled.

config BB_WIFI_GW_PROBE_ENABLE
    bool "Enable gateway-reachability probe worker (observe-only)"
    default n
    help
        When enabled, a dedicated worker task pings the STA default gateway
        every BB_WIFI_GW_PROBE_PERIOD_S seconds and records the result via
        bb_wifi_get_gateway_status(). OBSERVE-ONLY (B1-518): the probe never
        triggers recovery on its own — a bare gateway ping is not sufficient
        signal that egress is dead (see PR #578). Opt-in (default n): a
        periodic ping worker + dedicated task is not imposed on every
        breadboard consumer, matching the opt-in-for-expensive-features
        convention and the old B1-371 tick-driven probe's opt-in shape.
        Enable per-board in sdkconfig where fleet-wide egress observability
        is wanted.

config BB_WIFI_GW_PROBE_PERIOD_S
    int "Gateway-probe interval (seconds)"
    range 5 300
    default 20
    depends on BB_WIFI_GW_PROBE_ENABLE
    help
        How often the dedicated gateway-probe worker pings the STA default
        gateway.

config BB_WIFI_GW_PROBE_TIMEOUT_MS
    int "Gateway-probe ICMP timeout (ms)"
    range 100 5000
    default 1000
    depends on BB_WIFI_GW_PROBE_ENABLE
    help
        Timeout passed to bb_wifi_gateway_reachable() for each probe.

config BB_WIFI_GW_PROBE_FAILS
    int "Consecutive gateway-probe failures before fail-streak bump (observe-only)"
    range 1 20
    default 3
    depends on BB_WIFI_GW_PROBE_ENABLE
    help
        Fed into wifi_reconn_policy_on_egress_probe() as fail_threshold,
        using a SEPARATE observe-owned state — does not affect the live
        reconnect FSM. The resulting action is always discarded; this only
        sizes gw_fail_streak in bb_wifi_get_gateway_status().

config BB_WIFI_GW_PROBE_STACK
    int "Gateway-probe worker task stack size (bytes)"
    default 3072
    depends on BB_WIFI_GW_PROBE_ENABLE
    help
        Matches esp_ping's own task_stack_size (bb_wifi_ping uses 3072 for
        its lazy ping session).

config BB_WIFI_GW_PROBE_PRIORITY
    int "Gateway-probe worker task priority"
    default 3
    depends on BB_WIFI_GW_PROBE_ENABLE
    help
        FreeRTOS priority for the dedicated gateway-probe worker task.

endmenu
