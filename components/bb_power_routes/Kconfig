menu "breadboard: bb_power_routes"

config BB_POWER_ROUTES_AUTOREGISTER
    bool "Auto-register /api/power HTTP route via bb_registry"
    default y
    help
        When enabled, bb_power_routes self-registers GET /api/power through
        bb_registry at order 1 (after order-0 satellites have registered
        their extenders). Disable to call bb_power_routes_init manually.

endmenu
