menu "breadboard: bb_sink_http_telemetry"

config BB_SINK_HTTP_TELEMETRY_AUTOREGISTER
    bool "Auto-register http publish telemetry section via bb_init"
    default y
    depends on BB_TELEMETRY_AUTOREGISTER
    help
        When enabled, bb_sink_http_telemetry registers the "http" section with
        bb_telemetry at the PRE_HTTP tier. Disable to call
        bb_sink_http_telemetry_init manually.

endmenu
