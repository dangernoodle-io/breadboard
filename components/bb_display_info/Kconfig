menu "breadboard: bb_display_info"

config BB_DISPLAY_INFO_AUTO_ATTACH
    bool "Auto-attach health.display to /api/events"
    default n
    depends on BB_EVENT_ROUTES_AUTOREGISTER
    help
        When enabled, bb_display_register_info attaches the "health.display"
        topic to the bb_event_routes SSE stream so /api/events surfaces it
        without an explicit consumer call. Disable if a consumer wants the
        bb_event topic for internal logic only.
        Default n (opt-in): enable only on boards whose hardware this
        telemetry describes; without it the display panel source is never
        attached.

endmenu
