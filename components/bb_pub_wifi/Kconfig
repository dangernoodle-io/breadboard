menu "breadboard: bb_pub_wifi"

config BB_PUB_WIFI_AUTO_ATTACH
    bool "Auto-register wifi RSSI telemetry source with bb_pub"
    default y
    depends on BB_PUB_AUTOREGISTER
    help
        When enabled, bb_pub_wifi self-registers at the PRE_HTTP tier (after
        bb_pub) so wifi RSSI is published on every bb_pub tick under the
        "wifi" subtopic. The source is skipped (returns false) when the STA
        is not connected. Disable to call bb_pub_wifi_register() manually.

endmenu
