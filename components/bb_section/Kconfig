menu "breadboard: bb_section"

config BB_SECTION_MAX
    int "Maximum number of sections per registry"
    default 8
    range 1 32
    help
        Fixed-array capacity for sections in a bb_section_registry_t.
        Default 8 covers info (display+led+ntp+diag=4), sensors (3),
        telemetry (4), and health (2) with room to spare.

endmenu
