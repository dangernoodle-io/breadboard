menu "breadboard: bb_pub_health"

config BB_PUB_HEALTH_AUTO_ATTACH
    bool "Auto-register health telemetry source with bb_pub"
    default y
    depends on BB_PUB_AUTOREGISTER
    help
        When enabled, bb_pub_health self-registers at the PRE_HTTP tier (after
        bb_pub) so device health fields are published on every bb_pub tick
        under the "health" subtopic. Disable to call bb_pub_health_register()
        manually.

endmenu
