menu "breadboard: bb_net_health"

config BB_NET_HEALTH_AUTOSTART
    bool "Auto-start the net-health evaluator at PRE_HTTP"
    default y
    help
        When enabled, bb_net_health_start (cache mutex + evaluator timer)
        self-registers at the bb_init PRE_HTTP tier. Disable to call
        bb_net_health_start manually before bb_net_health_attach_sse.

config BB_NET_HEALTH_ROUTES_AUTOREGISTER
    bool "Auto-register /api/diag/net route via bb_init"
    default y
    help
        When enabled, bb_net_health registers GET /api/diag/net
        automatically via the bb_init regular tier after the HTTP server
        starts.

config BB_NET_HEALTH_RSSI_GOOD
    int "RSSI threshold for GOOD bucket (dBm)"
    default -67
    range -100 0
    help
        RSSI >= this value is classified as GOOD.

config BB_NET_HEALTH_RSSI_MARGINAL_LO
    int "Lower RSSI threshold for MARGINAL bucket (dBm)"
    default -75
    range -100 0
    help
        RSSI in the range [BB_NET_HEALTH_RSSI_MARGINAL_LO ..
        BB_NET_HEALTH_RSSI_GOOD-1] is classified as MARGINAL.
        RSSI below this value is classified as POOR.

config BB_NET_HEALTH_HYST_DOWN
    int "Hysteresis sample count before downgrading state"
    default 3
    range 1 10
    help
        Number of consecutive worse-bucket RSSI samples required before
        the published state is downgraded. Prevents single-sample flaps.

config BB_NET_HEALTH_HYST_UP
    int "Hysteresis sample count before upgrading state"
    default 3
    range 1 10
    help
        Number of consecutive better-bucket RSSI samples required before
        the published state is upgraded.

config BB_NET_HEALTH_EVAL_PERIOD_S
    int "Net-health evaluator period (seconds)"
    range 1 3600
    default 5
    help
        How often the net-health evaluator fires to sample RSSI and MQTT
        state and potentially publish a new "net.health" SSE snapshot.
        Default 5 s. Increasing this reduces CPU/WiFi polling; decreasing
        makes health transitions more responsive.

config BB_PUB_ADAPTIVE_BACKOFF
    bool "Adaptive bb_pub interval backoff on weak link"
    default n
    help
        When enabled, bb_net_health slows down the telemetry publish interval
        (via bb_pub_set_interval_ms) when the link is in a sustained POOR
        state, then restores the original interval on recovery.
        Default OFF — with the gate off there is ZERO behavioral change and
        the throttle decision code compiles out entirely.
        Gate: #if CONFIG_BB_PUB_ADAPTIVE_BACKOFF.

config BB_PUB_ADAPTIVE_RSSI_THRESH
    int "RSSI threshold for adaptive backoff (dBm)"
    default BB_NET_HEALTH_RSSI_MARGINAL_LO
    range -100 0
    depends on BB_PUB_ADAPTIVE_BACKOFF
    help
        RSSI below this value is considered weak for the purpose of adaptive
        backoff. DERIVE: defaults to BB_NET_HEALTH_RSSI_MARGINAL_LO so both
        the POOR-bucket lower bound and the adaptive-backoff threshold share a
        single source of truth (-75 dBm today). Override if you want backoff
        to trigger at a different threshold than the POOR bucket boundary.

config BB_PUB_ADAPTIVE_SLOW_MS
    int "Slowed publish interval during backoff (ms)"
    default 30000
    range 1000 3600000
    depends on BB_PUB_ADAPTIVE_BACKOFF
    help
        Publish interval applied via bb_pub_set_interval_ms when the link is
        in a sustained POOR state.

config BB_PUB_ADAPTIVE_SAMPLES
    int "Consecutive POOR samples before throttling"
    default 3
    range 1 20
    depends on BB_PUB_ADAPTIVE_BACKOFF
    help
        Number of consecutive POOR-state samples (at the 5s evaluator period)
        before bb_pub_set_interval_ms is called to slow publishing.

config BB_NET_HEALTH_HEAP_LOW_BYTES
    int "Free-heap LOW threshold (bytes)"
    default 40000
    range 1000 1000000
    help
        Total free heap bytes below which the heap state transitions to LOW.
        Applies to bb_board_heap_free_total() (PSRAM + internal on boards with
        PSRAM; internal-only on boards without). Tune down on boards with PSRAM
        where total free can be hundreds of KB.

config BB_NET_HEALTH_HEAP_CRITICAL_BYTES
    int "Free-heap CRITICAL threshold (bytes)"
    default 20000
    range 1000 1000000
    help
        Total free heap bytes below which the heap state transitions to CRITICAL.
        Must be less than BB_NET_HEALTH_HEAP_LOW_BYTES.

config BB_NET_HEALTH_HEAP_TRACE
    bool "Emit HEAPTRACE log line each eval cycle"
    default n
    help
        When enabled, eval_work_fn emits one bb_log_i(TAG, "HEAPTRACE ...") line
        every BB_NET_HEALTH_EVAL_PERIOD_S seconds with: uptime, global free/min/
        largest block, heap state bucket, and bb_mem accounting counters.
        Requires BB_MEM_STATS_ENABLE to populate the m_* fields; they will be
        zero otherwise (stats still disabled independently).
        Default OFF — zero runtime cost when disabled.

config BB_NET_HEALTH_LOG_INTERVAL_S
    int "Diagnostic heartbeat log interval (seconds)"
    default 60
    range 5 3600
    help
        Minimum interval between periodic heartbeat log lines when net_mode
        is unchanged (e.g. "still no_ip after 5min"). A net_mode transition
        always logs immediately regardless of this interval. The heartbeat
        itself is always compiled in (a few hundred bytes flash, zero heap)
        and controlled at runtime via the dedicated "net_state" log tag's
        level (default INFO = visible; lower the tag's level to suppress —
        no reflash required).

endmenu
