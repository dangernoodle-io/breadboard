menu "breadboard: bb_net_health"

config BB_NET_HEALTH_SSE_AUTO_ATTACH
    bool "Auto-attach 'net.health' retained SSE topic to /api/events"
    default y
    help
        When enabled (default), bb_net_health_attach_sse() attaches the
        retained "net.health" bb_event topic to /api/events, publishes an
        initial snapshot, and starts the periodic evaluator that re-publishes
        on state or early_warning change. Default y preserves the existing
        behavior for callers of bb_net_health_attach_sse() (B1-546); disable
        to make the call a no-op (e.g. when a board wants /api/health only,
        without the SSE topic).

config BB_NET_HEALTH_RSSI_GOOD
    int "RSSI threshold for GOOD bucket (dBm)"
    default -67
    range -100 0
    help
        RSSI >= this value is classified as GOOD.

config BB_NET_HEALTH_RSSI_MARGINAL_LO
    int "Lower RSSI threshold for MARGINAL bucket (dBm)"
    default -75
    range -100 0
    help
        RSSI in the range [BB_NET_HEALTH_RSSI_MARGINAL_LO ..
        BB_NET_HEALTH_RSSI_GOOD-1] is classified as MARGINAL.
        RSSI below this value is classified as POOR.

config BB_NET_HEALTH_HYST_DOWN
    int "Hysteresis sample count before downgrading state"
    default 3
    range 1 10
    help
        Number of consecutive worse-bucket RSSI samples required before
        the published state is downgraded. Prevents single-sample flaps.

config BB_NET_HEALTH_HYST_UP
    int "Hysteresis sample count before upgrading state"
    default 3
    range 1 10
    help
        Number of consecutive better-bucket RSSI samples required before
        the published state is upgraded.

config BB_NET_HEALTH_EVAL_PERIOD_S
    int "Net-health evaluator period (seconds)"
    range 1 3600
    default 5
    help
        How often the net-health evaluator fires to sample RSSI and MQTT
        state and potentially publish a new "net.health" SSE snapshot.
        Default 5 s. Increasing this reduces CPU/WiFi polling; decreasing
        makes health transitions more responsive.

config BB_NET_HEALTH_HEAP_LOW_BYTES
    int "Free-heap LOW threshold (bytes)"
    default 40000
    range 1000 1000000
    help
        Total free heap bytes below which the heap state transitions to LOW.
        Applies to bb_board_heap_free_total() (PSRAM + internal on boards with
        PSRAM; internal-only on boards without). Tune down on boards with PSRAM
        where total free can be hundreds of KB.

config BB_NET_HEALTH_HEAP_CRITICAL_BYTES
    int "Free-heap CRITICAL threshold (bytes)"
    default 20000
    range 1000 1000000
    help
        Total free heap bytes below which the heap state transitions to CRITICAL.
        Must be less than BB_NET_HEALTH_HEAP_LOW_BYTES.

config BB_NET_HEALTH_HEAP_TRACE
    bool "Emit HEAPTRACE log line each eval cycle"
    default n
    help
        When enabled, eval_work_fn emits one bb_log_i(TAG, "HEAPTRACE ...") line
        every BB_NET_HEALTH_EVAL_PERIOD_S seconds with: uptime, global free/min/
        largest block, heap state bucket, and bb_mem accounting counters.
        Requires BB_MEM_STATS_ENABLE to populate the m_* fields; they will be
        zero otherwise (stats still disabled independently).
        Default OFF — zero runtime cost when disabled.

config BB_NET_HEALTH_EGRESS_ACT_ENABLE
    bool "Enable egress-recovery ACT gate (tier-2 request_recovery + tier-3 reboot)"
    default n
    help
        When enabled, the evaluator ACTS on the egress-recovery SSOT
        classification instead of only logging it (B1-518 PR4):
          - tier-2: bb_wifi_request_recovery() is called on the edge
            transition into BB_EGRESS_STATE_GW_UNREACHABLE.
          - tier-3: if the gateway stays unreachable for
            BB_NET_HEALTH_EGRESS_ACT_REBOOT_S seconds, esp_restart() is
            called, rate-limited by BB_NET_HEALTH_EGRESS_ACT_REBOOT_MIN_INTERVAL_S
            and BB_NET_HEALTH_EGRESS_ACT_REBOOT_DAILY_CAP, persisted across
            reboots in NVS as real epoch seconds (time(NULL), never a
            boot-relative uptime — the rate limits must survive a reboot).
            Tier-3 is gated on bb_ntp_is_synced(): while the clock has never
            synced, tier-3 is log-only (no reboot, no NVS write) — tier-2
            is unaffected by this gate.
        Also retires the wifi_reconn safeguard-reboot escalation (the actual
        esp_restart() call) when enabled — see wifi_reconn.c.
        Default OFF — zero behavioral change; the whole act path compiles
        out. Gate: #if CONFIG_BB_NET_HEALTH_EGRESS_ACT_ENABLE.

config BB_NET_HEALTH_EGRESS_ACT_REBOOT_S
    int "Seconds of sustained GW_UNREACHABLE before tier-3 reboot"
    default 480
    range 60 3600
    depends on BB_NET_HEALTH_EGRESS_ACT_ENABLE
    help
        How long the gateway must stay unreachable (continuously) before
        the evaluator escalates to esp_restart().

config BB_NET_HEALTH_EGRESS_ACT_REBOOT_MIN_INTERVAL_S
    int "Minimum seconds between tier-3 reboots"
    default 1800
    range 300 86400
    depends on BB_NET_HEALTH_EGRESS_ACT_ENABLE
    help
        Rate-limit: at most one tier-3 reboot per this many seconds,
        persisted across reboots in NVS.

config BB_NET_HEALTH_EGRESS_ACT_REBOOT_DAILY_CAP
    int "Maximum tier-3 reboots per rolling 24h"
    default 4
    range 1 10
    depends on BB_NET_HEALTH_EGRESS_ACT_ENABLE
    help
        Hard cap on tier-3 reboots within a rolling 24h window, persisted
        across reboots in NVS (ring buffer of reboot timestamps).

config BB_NET_HEALTH_LOG_INTERVAL_S
    int "Diagnostic heartbeat log interval (seconds)"
    default 60
    range 5 3600
    help
        Minimum interval between periodic heartbeat log lines when net_mode
        is unchanged (e.g. "still no_ip after 5min"). A net_mode transition
        always logs immediately regardless of this interval. The heartbeat
        itself is always compiled in (a few hundred bytes flash, zero heap)
        and controlled at runtime via the dedicated "net_state" log tag's
        level (default INFO = visible; lower the tag's level to suppress —
        no reflash required).

endmenu
