menu "breadboard: bb_sensors"

config BB_SENSORS_PATCH_BODY_MAX
    int "Maximum PATCH /api/sensors body size (bytes)"
    default 256
    range 64 4096
    help
        Hard cap on the PATCH /api/sensors request body. Requests larger
        than this are rejected with 400 before any parsing occurs.
        Default 256 bytes is sufficient for full autofan config payloads.
        Raise for consumers that add large section PATCH payloads.

endmenu
