menu "breadboard: bb_nv"

config BB_NV_FLASH_AUTOREGISTER
    bool "Auto-init NVS partition (nvs_flash_init) via bb_registry early tier"
    default y

config BB_NV_CONFIG_AUTOREGISTER
    bool "Auto-load breadboard typed config (wifi creds, display flag) via bb_registry early tier"
    default y

config BB_NV_CONFIG_MANIFEST_AUTOREGISTER
    bool "Auto-register bb_cfg NVS keys with /api/manifest via bb_registry pre_http tier"
    default y
    depends on BB_MANIFEST_AUTOREGISTER

config BB_NV_CREDS_RTC_BACKUP
    bool "Back up wifi creds to RTC slow memory (survive NVS erase-on-corruption)"
    default y
    help
      Mirrors wifi ssid/pass/provisioned (~108 bytes) into RTC_NOINIT memory so a
      crash-induced NVS erase doesn't strand a headless board. Survives software
      reset/panic; lost on full power-off. See B1-242.

endmenu
