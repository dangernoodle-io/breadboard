menu "breadboard: bb_lifecycle"

config BB_LIFECYCLE_MAX_SERVICES
    int "Max registered services"
    default 8
    range 1 255
    help
        Fixed-capacity table size for bb_lifecycle_register(). Registration
        beyond this cap fails with BB_ERR_NO_SPACE.

config BB_LIFECYCLE_MAX_OBSERVERS
    int "Max PUSH observers"
    default 8
    range 1 255
    help
        Fixed-capacity table size for bb_lifecycle_observe(). Registration
        beyond this cap fails with BB_ERR_NO_SPACE.

config BB_LIFECYCLE_MAX_REASONS
    int "Max distinct interned pause reasons"
    default 32
    range 1 255
    help
        Fixed-capacity global reason-string intern table shared by every
        service. A brand-new reason string once this table is full fails
        with BB_ERR_NO_SPACE.

config BB_LIFECYCLE_NAME_MAX
    int "Max service name length (bytes, incl. NUL)"
    default 24
    range 1 255
    help
        Service names longer than this are truncated on registration.

config BB_LIFECYCLE_REASON_MAX
    int "Max pause reason string length (bytes, incl. NUL)"
    default 24
    range 1 255
    help
        Pause reason strings longer than this are truncated on intern; two
        reasons sharing the same truncated prefix map to the same bit.

config BB_LIFECYCLE_ASYNC_QUEUE_DEPTH
    int "Async observer queue depth"
    default 8
    range 1 64
    help
        Bounded-MPSC capacity of the shared async dispatch queue. A full
        queue drops the event (bb_bqueue_dropped() counter; rate-limited
        warn log) rather than blocking the emitter.

config BB_LIFECYCLE_ASYNC_TASK_STACK
    int "Async observer drain task stack (bytes)"
    default 3072
    range 2048 8192

config BB_LIFECYCLE_ASYNC_TASK_PRIORITY
    int "Async observer drain task priority"
    default 3
    range 1 20

config BB_LIFECYCLE_ASYNC_TASK_CORE
    int "Async observer drain task core affinity (-1 = no affinity)"
    default -1
    range -1 1

endmenu
