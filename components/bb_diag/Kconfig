menu "breadboard: bb_diag"

config BB_DIAG_PANIC_CAPTURE
    bool "Capture log tail to RTC RAM for panic diagnosis"
    default y
    help
        Mirrors bb_log_stream output to RTC slow memory so the last
        few KB of log lines survive a software reboot. Exposed via
        GET /api/diag/panic on the next boot if the previous boot was
        abnormal (panic, watchdog, brownout). Costs CONFIG_BB_DIAG_PANIC_BUF_SIZE
        bytes of RTC slow memory.

config BB_DIAG_PANIC_BUF_SIZE
    int "Panic log RTC buffer size (bytes)"
    default 1024
    range 512 8192
    depends on BB_DIAG_PANIC_CAPTURE
    help
        Size of the circular buffer in RTC slow memory. Must fit in
        the chip's RTC slow memory budget (~8KB on ESP32-S3, less on
        smaller chips). ~30 lines fit in 1024 bytes; raise if you need
        deeper panic context. Default 1024 saves 1 KB RTC slow memory
        vs the old default of 2048.

config BB_DIAG_PANIC_COREDUMP
    bool "Capture ESP-IDF coredump for panic backtraces"
    default n
    depends on BB_DIAG_PANIC_CAPTURE
    help
        On panic, ESP-IDF writes a coredump to a dedicated flash partition.
        On the next boot, bb_diag_panic decodes it via esp_core_dump_get_summary
        and exposes the task name, exception PC, and backtrace via
        GET /api/diag/panic. Requires a "coredump" partition entry in the
        consumer's partitions.csv (see examples/smoke/partitions.*.csv for
        the 64 KB layout). Also requires the following in sdkconfig.defaults:
            CONFIG_ESP_COREDUMP_ENABLE_TO_FLASH=y
            CONFIG_ESP_COREDUMP_DATA_FORMAT_ELF=y
            CONFIG_ESP_COREDUMP_CHECKSUM_CRC32=y
        Disabled by default to avoid forcing the partition change on existing
        consumers.


# BB_DIAG_ROUTES, BB_DIAG_PANIC_TRIGGER, and BB_DIAG_SECTIONS moved to
# bb_diag_http's own Kconfig menu (B1-1153, KB 1477) -- they now gate that
# component's own SRCS, not bb_diag's. Same symbol names, relocated
# ownership: existing sdkconfig files need no changes (Kconfig symbols are a
# flat, global namespace regardless of which component's Kconfig declares
# them -- same precedent as bb_wifi_http's CONFIG_BB_WIFI_ROUTES_AUTOREGISTER
# relocation).

config BB_DIAG_SECTION_SCRATCH_BYTES
    int "Shared render scratch buffer size (bytes)"
    default 1536
    range 64 4096
    depends on BB_DIAG_SECTIONS
    help
        Size of the stack buffer a dispatched /api/diag/<name> request
        fills a section's snapshot into before rendering. Every
        registered section's snap_desc->snap_size must fit within this
        bound -- bb_diag_register_section() rejects (BB_ERR_NO_SPACE) any
        section whose snapshot exceeds it, rather than truncating at
        request time. Default raised from 512 to 1536 (B1-767 PR9) to fit
        the storage/nvs and storage/partitions sections' snapshots
        (~1.3KB / ~1KB at their default caps) with headroom.

config BB_DIAG_STORAGE_PARTITIONS_ROW_CAP
    int "storage/partitions section: max partition rows per response"
    default 16
    range 1 32
    depends on BB_DIAG_SECTIONS
    help
        Caller-allocated array capacity for the GET
        /api/diag/storage/partitions section's row list. Matches the
        existing legacy /api/diag/partitions handler's hardcoded parts[16]
        (bb_partition_routes.c) -- same precedent, not invented.

config BB_DIAG_SECTION_QUERY_VALUE_BYTES
    int "Per-query-param value buffer size (bytes)"
    default 32
    range 8 256
    depends on BB_DIAG_SECTIONS
    help
        Size of the stack buffer used to hold one query-string value while
        threading a section's declared query_keys through to its fill
        hook. A value longer than this is truncated (same convention as
        bb_http_req_query_key_value()).

endmenu
